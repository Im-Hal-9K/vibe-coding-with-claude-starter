// Vibe Coding with Claude - student Codespace.
// Everything runs in the browser. A student opens this repo in a Codespace and
// the Claude tooling + a live preview are ready. No installs on their machine.
{
  "name": "Vibe Coding with Claude",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",

  // Live preview of whatever the student builds (Claude usually serves on one of these).
  "forwardPorts": [3000, 5500, 8080],
  "portsAttributes": {
    "3000": { "label": "Preview", "onAutoForward": "openPreview" },
    "5500": { "label": "Live Server" },
    "8080": { "label": "Preview alt" }
  },

  // Installs the Claude Code CLI + a preview server AND pre-answers Claude's
  // first-run prompts (theme, onboarding, folder trust) so students land
  // straight in the REPL. See .devcontainer/setup.sh.
  "postCreateCommand": "bash .devcontainer/setup.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        // VERIFY this id at the dry run; if the panel extension differs, the CLI
        // (`claude` in the terminal) is the reliable fallback and needs no extension.
        "anthropic.claude-code",
        "ms-vscode.live-server"
      ]
    }
  },

  // ---- API KEY WIRING: proxy, key pasted in class (no secret committed) ----
  // The proxy URL below is public/non-secret. Claude routes all calls through the
  // class proxy. Students set the throwaway class key once per session with
  //   export ANTHROPIC_API_KEY=<key the instructor shows on screen>
  // (see README step 2), then run `claude`. The key is capped by the proxy's
  // spend-limited Anthropic key and revoked after class. No credential lives here.
  "remoteEnv": {
    "ANTHROPIC_BASE_URL": "https://vibe-class-claude-proxy.hfgott0.workers.dev",
    // Pin to the model the class key is cleared for, so no student hits a
    // model-not-found error. Both the main and background models use it.
    "ANTHROPIC_MODEL": "claude-haiku-4-5-20251001",
    "ANTHROPIC_SMALL_FAST_MODEL": "claude-haiku-4-5-20251001"
  }
}
